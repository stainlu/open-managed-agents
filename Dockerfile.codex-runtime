# Open Managed Agents - Codex adapter runtime image
#
# Runs one Codex app-server instance behind the internal oma.adapter.v1
# HTTP/SSE protocol. The orchestrator owns managed session lifecycle,
# isolation, queues, policy, and the public API; Codex owns the agent loop.

FROM node:22-bookworm-slim

ARG CODEX_NPM_VERSION=0.128.0
ARG CODEX_APP_SERVER_SDK_REF=7dd08e304ce85d9df11dea3f6e065fc313fbadd5

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        python3 \
        python3-venv \
        tini \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g "@openai/codex@${CODEX_NPM_VERSION}"

RUN python3 -m venv /opt/oma-codex-venv \
    && /opt/oma-codex-venv/bin/python -m pip install --no-cache-dir --upgrade pip \
    && /opt/oma-codex-venv/bin/python -m pip install --no-cache-dir \
        "openai-codex-app-server-sdk @ git+https://github.com/openai/codex.git@${CODEX_APP_SERVER_SDK_REF}#subdirectory=sdk/python"

RUN groupadd -r codex && useradd -r -g codex -m -d /home/codex codex
RUN mkdir -p /workspace /opt/oma-codex-adapter \
    && chown -R codex:codex /workspace /home/codex /opt/oma-codex-adapter

COPY docker/codex-adapter/oma_codex_adapter.py /opt/oma-codex-adapter/oma_codex_adapter.py

USER codex
WORKDIR /workspace

ENV PATH="/opt/oma-codex-venv/bin:${PATH}" \
    OMA_ADAPTER_PROTOCOL="oma.adapter.v1" \
    OMA_ADAPTER_HARNESS_ID="codex" \
    OMA_ADAPTER_PORT="18789" \
    OPENCLAW_GATEWAY_PORT="18789" \
    OMA_STATE_DIR="/workspace" \
    OMA_CODEX_BIN="/usr/local/bin/codex" \
    OMA_CODEX_HOME="/workspace/.codex" \
    CODEX_HOME="/workspace/.codex" \
    OMA_CODEX_CWD="/workspace" \
    PYTHONUNBUFFERED="1"

EXPOSE 18789

HEALTHCHECK --interval=10s --timeout=3s --start-period=30s --retries=5 \
    CMD curl --silent --fail "http://127.0.0.1:${OMA_ADAPTER_PORT}/readyz" || exit 1

ENTRYPOINT ["/usr/bin/tini", "--", "python", "/opt/oma-codex-adapter/oma_codex_adapter.py"]
