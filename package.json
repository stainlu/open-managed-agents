{
  "name": "open-managed-agents",
  "version": "0.1.0",
  "description": "The open managed-agent layer for multiple agent harnesses. Initial baseline ships the OpenClaw adapter.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "open-managed-agents": "dist/index.js"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/orchestrator/portal-v2.html dist/orchestrator/portal-v2.html",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:e2e": "bash test/e2e.sh",
    "lint": "tsc --noEmit -p tsconfig.json",
    "docker:build-runtime": "docker build -f Dockerfile.runtime -t open-managed-agents/openclaw-agent:latest .",
    "docker:build-hermes-runtime": "docker build -f Dockerfile.hermes-runtime -t open-managed-agents/hermes-agent:latest .",
    "docker:build-codex-runtime": "docker build -f Dockerfile.codex-runtime -t open-managed-agents/codex-agent:latest .",
    "docker:build-claude-agent-sdk-runtime": "docker build -f Dockerfile.claude-agent-sdk-runtime -t open-managed-agents/claude-agent-sdk-agent:latest .",
    "docker:build-orchestrator": "docker build -f Dockerfile.orchestrator -t open-managed-agents/orchestrator:latest .",
    "docker:build": "pnpm docker:build-runtime && pnpm docker:build-hermes-runtime && pnpm docker:build-codex-runtime && pnpm docker:build-claude-agent-sdk-runtime && pnpm docker:build-orchestrator"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^11.3.0",
    "dockerode": "^4.0.2",
    "hono": "^4.6.0",
    "nanoid": "^5.0.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "ws": "^8.20.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/dockerode": "^3.3.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
